Cell[CellGroupData[{
Cell[TextData[{
 "Expression of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"colored", " ", 
    SubscriptBox["\[CapitalDelta]", "T"], "noise"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a86ed9bf-f45d-a741-922a-53c1d49b380a"]
}], "Title",
 CellChangeTimes->{{3.986245817477154*^9, 
  3.986245839465309*^9}},ExpressionUUID->"e2e95560-81f5-af47-9729-\
564897e071f3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f1", "[", 
    RowBox[{"G_", ",", "\[Omega]_", ",", "x_"}], "]"}], ":=", 
   FractionBox["1", 
    RowBox[{"1", "+", 
     RowBox[{"Exp", "[", 
      FractionBox[
       RowBox[{"G", "+", 
        RowBox[{"\[Omega]", "*", "10"}]}], 
       RowBox[{"1", "+", 
        RowBox[{"x", "/", "2"}]}]], "]"}]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f2", "[", 
    RowBox[{"G_", ",", "\[Omega]_", ",", "x_"}], "]"}], ":=", 
   FractionBox["1", 
    RowBox[{"1", "+", 
     RowBox[{"Exp", "[", 
      FractionBox[
       RowBox[{"G", "+", 
        RowBox[{"\[Omega]", "*", "10"}]}], 
       RowBox[{"1", "-", 
        RowBox[{"x", "/", "2"}]}]], "]"}]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"D1", "[", 
   RowBox[{
    RowBox[{"\[Omega]_", "?", "NumericQ"}], ",", 
    RowBox[{"x_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{"0.25", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"f2", "[", 
         RowBox[{"G", ",", "0", ",", "x"}], "]"}], "-", 
        RowBox[{"f1", "[", 
         RowBox[{"G", ",", "0", ",", "x"}], "]"}]}], ")"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"f2", "[", 
         RowBox[{"G", ",", "\[Omega]", ",", "x"}], "]"}], "-", 
        RowBox[{"f1", "[", 
         RowBox[{"G", ",", "\[Omega]", ",", "x"}], "]"}]}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"G", ",", 
       RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}]}], 
    "]"}]}]}]}], "Input",
 CellLabel->"In[19]:=",ExpressionUUID->"ac212ac3-2f82-764f-8bb0-d94bcbdd8fbc"]
}, Open  ]],

